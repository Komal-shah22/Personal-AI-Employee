# Social Media MCP Server Environment Variables

# ============================================================================
# DRY RUN MODE
# ============================================================================
# Set to 'false' to actually post to social media
# Default: true (safe mode - no actual posts)
DRY_RUN=true

# ============================================================================
# TWITTER / X API CREDENTIALS
# ============================================================================
# Get credentials from: https://developer.twitter.com/en/portal/dashboard
# Required for: post_twitter

# Twitter API v2 Bearer Token (for read operations)
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Twitter API v1.1 OAuth 1.0a credentials (for posting)
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here

# ============================================================================
# FACEBOOK API CREDENTIALS
# ============================================================================
# Get credentials from: https://developers.facebook.com/apps/
# Required for: post_facebook

# Facebook User Access Token (long-lived recommended)
FB_ACCESS_TOKEN=your_facebook_access_token_here

# Facebook Page ID (optional - if posting to a page instead of personal timeline)
# Find at: https://www.facebook.com/[your-page]/about
FB_PAGE_ID=your_page_id_here

# ============================================================================
# INSTAGRAM API CREDENTIALS
# ============================================================================
# Requires: Facebook Business account + Instagram Business/Creator account
# Get credentials from: https://developers.facebook.com/apps/
# Required for: post_instagram

# Instagram User ID (your Instagram Business account ID)
INSTAGRAM_USER_ID=your_instagram_user_id_here

# Instagram Access Token (from Facebook Graph API)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here

# ============================================================================
# NOTES
# ============================================================================
#
# Twitter Setup:
# 1. Create app at https://developer.twitter.com/en/portal/dashboard
# 2. Enable OAuth 1.0a with Read and Write permissions
# 3. Generate API keys and access tokens
# 4. Copy all 5 credentials above
#
# Facebook Setup:
# 1. Create app at https://developers.facebook.com/apps/
# 2. Add "Facebook Login" product
# 3. Generate User Access Token with 'pages_manage_posts' permission
# 4. For pages: Get Page ID from page settings
#
# Instagram Setup:
# 1. Convert Instagram account to Business/Creator account
# 2. Link to Facebook Page
# 3. Create Facebook app with Instagram Graph API
# 4. Generate access token with 'instagram_basic', 'instagram_content_publish'
# 5. Get Instagram User ID from Graph API
#
# Security:
# - NEVER commit .env file to git
# - Use long-lived tokens when possible
# - Rotate tokens regularly
# - Keep DRY_RUN=true until fully tested
#

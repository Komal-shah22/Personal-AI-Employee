# Environment Variables Template for Cloud Deployment
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to Git!

# ============================================================================
# CRITICAL SECURITY NOTES
# ============================================================================
# 1. This file contains sensitive credentials - NEVER commit to Git
# 2. Set restrictive permissions: chmod 600 .env
# 3. Use Oracle Vault for production secrets (recommended)
# 4. WhatsApp sessions MUST stay LOCAL only (never cloud)
# 5. Payment MCP MUST stay LOCAL only (never cloud)
# 6. Review all values before deployment
# 7. Set DRY_RUN=true until fully tested

# ============================================================================
# CORE CONFIGURATION (REQUIRED)
# ============================================================================

# Claude API Key (REQUIRED)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Environment
NODE_ENV=production

# Timezone (UTC recommended for servers)
TZ=UTC

# Dry Run Mode (set to false when ready for production)
DRY_RUN=true

# ============================================================================
# EMAIL MCP (OPTIONAL)
# ============================================================================
# Gmail API credentials
# Get from: https://console.cloud.google.com/

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ============================================================================
# SOCIAL MEDIA MCP (OPTIONAL)
# ============================================================================

# Twitter/X API
# Get from: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Facebook API
# Get from: https://developers.facebook.com/
FB_ACCESS_TOKEN=
FB_PAGE_ID=

# Instagram API
# Get from: https://developers.facebook.com/
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# ============================================================================
# ODOO ERP (OPTIONAL)
# ============================================================================
# Odoo connection details

ODOO_URL=
ODOO_DB=
ODOO_API_USER=
ODOO_API_PASSWORD=

# ============================================================================
# MONITORING & ALERTS (OPTIONAL)
# ============================================================================

# Email for health check alerts
ALERT_EMAIL=

# SMTP settings for sending alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================================================================
# IMPORTANT: NEVER SET THESE IN CLOUD
# ============================================================================
# These services MUST stay on local machine only for security:
#
# WhatsApp (contains authentication sessions):
# - WHATSAPP_* (any WhatsApp-related variables)
#
# Payment MCP (handles financial transactions):
# - PAYMENT_* (any payment-related variables)
# - STRIPE_* (Stripe API keys)
# - PAYPAL_* (PayPal credentials)
#
# If you need these services, run them on your local machine
# and use the cloud deployment only for non-sensitive tasks.

# ============================================================================
# DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production:
#
# [ ] All required API keys are set
# [ ] DRY_RUN is set appropriately
# [ ] File permissions are restrictive (chmod 600 .env)
# [ ] .env is in .gitignore
# [ ] No WhatsApp or Payment credentials
# [ ] Tested in DRY_RUN mode first
# [ ] Monitoring and alerts configured
# [ ] Backup system in place
# [ ] Firewall rules configured
# [ ] SSH key-only authentication enabled
#
# ============================================================================

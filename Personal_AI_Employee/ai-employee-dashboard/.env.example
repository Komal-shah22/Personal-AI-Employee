# ========================================
# AI EMPLOYEE DASHBOARD - ENVIRONMENT CONFIG
# ========================================

# Path to AI Employee Vault (where all markdown files are stored)
VAULT_PATH=E:/hackathon-0/Personal_AI_Employee/AI_Employee_Vault

# Path to Python scripts directory
SCRIPTS_PATH=E:/hackathon-0/Personal_AI_Employee

# PM2 home directory (optional, for agent control)
PM2_HOME=C:/Users/YourUser/.pm2

# Task Scheduler (Windows only)
TASK_SCHEDULER_ENABLED=false

# App Configuration
NEXT_PUBLIC_APP_NAME=Personal AI Employee Dashboard
NEXT_PUBLIC_REFRESH_INTERVAL=5000

# Custom port (optional, defaults to 3000)
PORT=3000

# ========================================
# OPTIONAL: API Keys (if using MCP servers)
# ========================================

# Gmail MCP
# GMAIL_CLIENT_ID=your-client-id
# GMAIL_CLIENT_SECRET=your-client-secret

# LinkedIn MCP
# LINKEDIN_ACCESS_TOKEN=your-access-token

# Slack MCP
# SLACK_BOT_TOKEN=your-bot-token
